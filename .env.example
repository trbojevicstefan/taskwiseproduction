# Copy this file to `.env.local` (or `.env`) and set real values via your secret manager.
# Do not commit real credentials.

# Core local runtime
MONGODB_URI=CHANGE_ME
MONGODB_DB=CHANGE_ME
NEXTAUTH_URL=CHANGE_ME
NEXTAUTH_SECRET=CHANGE_ME

# AI features
OPENAI_API_KEY=CHANGE_ME

# Legacy placeholders kept for compatibility; currently not referenced in app code
NEXT_PUBLIC_FIREBASE_API_KEY=CHANGE_ME
NEXT_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLEOAUTH_CLIENT_ID=CHANGE_ME

# Optional OAuth providers and integrations
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_INTEGRATION_CLIENT_ID=CHANGE_ME
GOOGLE_INTEGRATION_CLIENT_SECRET=CHANGE_ME

# Optional AI providers

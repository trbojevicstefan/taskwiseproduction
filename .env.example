# Copy this file to `.env.local` (or `.env`) and set real values via your secret manager.
# Do not commit real credentials.

# Core local runtime
MONGODB_URI=
MONGODB_DB=
NEXTAUTH_URL=http://localhost:9002
NEXTAUTH_SECRET=

# AI features
OPENAI_API_KEY=
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_FALLBACK_MODEL=gpt-4.1-nano
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSLATE_MODEL=gpt-4.1-mini
GENKIT_DEFAULT_MODEL=googleai/gemini-2.5-flash-lite

# Legacy placeholders kept for compatibility; currently not referenced in app code
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLEOAUTH_CLIENT_ID=

# Optional OAuth providers and integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=

# Optional AI providers
GEMINI_API_KEY=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

FATHOM_CLIENT_ID=
FATHOM_CLIENT_SECRET=
FATHOM_WEBHOOK_SECRET=
FATHOM_OAUTH_REDIRECT_URI=
FATHOM_PUBLIC_BASE_URL=

OPENAI_USAGE_DEBUG=0
OPENAI_USAGE_LOG_FILE=
VERCEL_OIDC_TOKEN=

# Workspace rollout flags
WORKSPACE_SWITCHER_ENABLED=0
WORKSPACE_MEMBERSHIP_GUARD_ENABLED=0
WORKSPACE_INVITE_MEMBERSHIP_MODE_ENABLED=0

# Operational route hardening (keep disabled in production by default)
ENABLE_OPERATIONAL_ROUTES=0
OPERATIONAL_ROUTE_ALLOWED_USER_IDS=

# Core-first rollout flags (disabled by default)
CORE_FIRST_QUEUE_FIRST_WEBHOOK_INGESTION=0
CORE_FIRST_UNIFIED_MEETING_INGESTION_COMMAND=0
CORE_FIRST_ASYNC_DOMAIN_EVENT_PROCESSING=0

# Domain event retention policy (days)
DOMAIN_EVENT_RETENTION_DAYS=30

# Job worker backlog thresholds
JOB_BACKLOG_WARN_THRESHOLD=100
JOB_BACKLOG_CRITICAL_THRESHOLD=500
JOB_WORKER_BACKLOG_LOG_INTERVAL_MS=60000
